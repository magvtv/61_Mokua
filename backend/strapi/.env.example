# Strapi CMS Environment Variables

# Server
HOST=0.0.0.0
PORT=1337

# Secrets (generate with: openssl rand -base64 32)
APP_KEYS=your-app-keys-here-comma-separated
API_TOKEN_SALT=your-api-token-salt
ADMIN_JWT_SECRET=your-admin-jwt-secret
TRANSFER_TOKEN_SALT=your-transfer-token-salt
JWT_SECRET=your-jwt-secret

# Database (PostgreSQL for production)
DATABASE_CLIENT=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=mokua_cms
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your-password
DATABASE_SSL=false

# Or SQLite for development (simpler)
# DATABASE_CLIENT=sqlite
# DATABASE_FILENAME=.tmp/data.db

# External Auth Provider (choose one)
# Clerk
EXTERNAL_AUTH_PROVIDER=clerk
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# Supabase
# EXTERNAL_AUTH_PROVIDER=supabase
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Auth0
# EXTERNAL_AUTH_PROVIDER=auth0
# AUTH0_DOMAIN=
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=

# Media Storage (Cloudinary)
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

# Email Service (optional)
EMAIL_PROVIDER=
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
