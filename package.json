{
    "name": "mokua-rise-above",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev:all": "concurrently \"pnpm --filter frontend dev\" \"pnpm --filter api-server dev\" \"pnpm --filter strapi develop\"",
        "dev:frontend": "pnpm --filter frontend dev",
        "dev:api": "pnpm --filter api-server dev",
        "dev:strapi": "pnpm --filter strapi develop",
        "build:frontend": "pnpm --filter frontend build",
        "build:api": "pnpm --filter api-server build",
        "build:all": "pnpm build:frontend && pnpm build:api",
        "install:all": "pnpm install",
        "lint": "pnpm --filter frontend lint && pnpm --filter api-server lint"
    },
    "dependencies": {},
    "devDependencies": {
        "concurrently": "^9.1.2"
    },
    "packageManager": "pnpm@8.14.2+sha256.a2dd287205a53bb4322937530d4a17f86269f63fe00a62a03e9e458d3ad027ff"
}
